# ─── Required ───
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ops_blog
JWT_SECRET=your-secret-key-here
OPENAI_API_KEY=sk-...

# ─── Embedding Provider ───
# "ollama" (default, for local dev) or "openai" (for production/cloud)
EMBEDDING_PROVIDER=ollama

# Only needed if EMBEDDING_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434

# ─── Optional ───
JWT_ALGO=HS256
UPLOAD_DIR=uploads
CHROMA_DB_PATH=./chroma_db
CORS_ORIGINS=http://localhost:5173
